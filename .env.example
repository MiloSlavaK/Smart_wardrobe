# Скопируйте этот файл в .env и заполните своими значениями
# Получите токен в кабинете разработчика SaluteDev

# Токен для аутентификации в SaluteDev
# Как получить: https://smartapp-code.sberdevices.ru/ -> Настройки проекта -> Токен
REACT_APP_TOKEN="ваш_токен_от_SaluteDev"

# Имя вашего SmartApp (указывается при создании проекта в SaluteDev)
REACT_APP_SMARTAPP="имя_вашего_smartapp"
